{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "corepack pnpm --filter @stablebooks/api build"
  },
  "deploy": {
    "preDeployCommand": "corepack pnpm --filter @stablebooks/api exec prisma migrate deploy",
    "startCommand": "corepack pnpm --filter @stablebooks/api start",
    "healthcheckPath": "/api/v1/health/live",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
